# ============================================================
#  Copy this file to .env.local for local development, and set
#  the same variables in your Vercel project settings for
#  deployment. Never commit the real .env.local file.
# ============================================================

# --- Supabase (server-side only — do NOT prefix with NEXT_PUBLIC_) ----
# Found in Supabase project settings -> API.
SUPABASE_URL=https://your-project.supabase.co
# The SERVICE ROLE key (not the anon/public key). This bypasses RLS and
# must only ever be read on the server.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Privacy / IP handling ---------------------------------------------
# Random long random string, used to salt the SHA-256 hash of visitor
# IPs. Generate with: openssl rand -hex 32
IP_HASH_SALT=replace-with-a-long-random-string

# When false (default), only a salted hash of the IP is stored.
# Set to true only if you deliberately want to store raw IP addresses.
STORE_FULL_IP=false

# How many days of visit/response logs to retain before automatic
# deletion via /api/cleanup.
RETENTION_DAYS=30

# --- Admin page ----------------------------------------------------------
# Password required to view /admin.
ADMIN_PASSWORD=choose-a-strong-password
# Random secret used to sign admin session + CSRF cookies.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# --- Scheduled cleanup ----------------------------------------------------
# Bearer secret required by /api/cleanup. When this env var is named
# CRON_SECRET, Vercel Cron automatically sends it as
# `Authorization: Bearer $CRON_SECRET` — no extra config needed.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string
